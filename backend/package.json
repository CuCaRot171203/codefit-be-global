{
  "name": "backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "dev": "nodemon --exec \"tsx\" server.ts",
    "build": "esbuild ./server.ts --bundle --platform=node --outfile=dist/server.js --format=cjs --sourcemap --packages=external",
    "build:seed": "esbuild ./prisma/seed.ts --bundle --platform=node --outfile=dist/prisma/seed.js --format=cjs --packages=external",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:seed:full": "npx tsx prisma/seed-full.ts",
    "db:seed:admin": "npx tsx prisma/seed-admin.ts"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@payos/node": "^2.0.5",
    "@prisma/client": "^6.19.3",
    "@types/nodemailer": "^8.0.0",
    "amqplib": "^1.0.3",
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "imagekit": "^6.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^6.10.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "prisma": "^6.19.3",
    "sepay-pg-node": "^1.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.7",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
