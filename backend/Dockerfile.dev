# Dockerfile cho CodeFit Backend - Development
# Chạy trực tiếp TypeScript với hot-reload (tsx/nodemon)

FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install ALL dependencies (không prune, giữ devDependencies)
RUN npm ci

# Copy source code
COPY . .

# Generate Prisma client
RUN npx prisma generate

# Expose port
EXPOSE 5000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:5000/api/health || exit 1

# Start với tsx (TypeScript executor, hỗ trợ --watch)
# tsx watch tự detect file changes và restart
CMD ["npx", "tsx", "watch", "--watch", "server.ts"]
